# Godot 4+ specific ignores
# Keep UID cache for stable resource UID resolution across machines.
.godot/*
!.godot/uid_cache.bin
!.godot/.gdignore
android/

# Godot-specific ignores
.import/
export.cfg
export_presets.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# System/tool-specific ignores
.directory
*~
*.swp
*.swo
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.csproj
*.sln

# Build
build/
dist/
*.tmp

# Sessions
sessions/

# OMO
.sisyphus/
conversations/

# Temp/test files
nul
test_*.gd
!tests/
!tests/**/*.gd
!tests/**/*.gd.uid
