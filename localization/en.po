# Crosshair Tooltips
msgid "ui.settings.crosshair.tooltip.t_shape"
msgstr "Turns the crosshair into a three-arm T by hiding the upper segment."

msgid "ui.settings.crosshair.tooltip.color_mode"
msgstr "Choose a fast preset color or fine-tune the crosshair with custom RGB sliders."

msgid "ui.settings.crosshair.tooltip.line_gap"
msgstr "Controls the empty space between the center point and the outer line segments."

msgid "ui.settings.crosshair.tooltip.outline"
msgstr "Adds a dark border behind the crosshair so it stays readable on bright backgrounds."

msgid "ui.settings.crosshair.tooltip.dynamic_spread"
msgstr "When enabled, the crosshair expands while firing and recovers over time to preview weapon spread."

msgid "ui.settings.crosshair.tooltip.hit_feedback"
msgstr "Shows an extra hit marker pulse when your shots connect."

msgid "ui.settings.crosshair.tooltip.hit_feedback_duration"
msgstr "How long each hit pulse remains visible before fading out."

msgid "ui.settings.crosshair.tooltip.hit_feedback_scale"
msgstr "Sets the base size of the hit pulse relative to the current crosshair."

msgid "ui.settings.crosshair.tooltip.hit_feedback_expand_ratio"
msgstr "How much the hit pulse grows outward during its animation."

msgid "ui.settings.crosshair.tooltip.hit_feedback_pulse_speed"
msgstr "Controls how quickly the hit pulse breathes during its short animation."

msgid "ui.settings.crosshair.tooltip.hit_feedback_max_stacks"
msgstr "Maximum number of overlapping hit pulses allowed at once."

msgid "ui.settings.crosshair.tooltip.hit_feedback_stacking_mode"
msgstr "Replace refreshes the latest pulse, Stack layers multiple pulses, Ignore New keeps the current one."

